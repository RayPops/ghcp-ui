        <!-- Title -->
        <mxCell id="df-title" value="Data Flow: Scheduling Decision for One Work Order" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Input -->
        <mxCell id="df-csv-row" value="&lt;b&gt;CSV Row&lt;/b&gt;&lt;br&gt;order_id, service_type, job_type,&lt;br&gt;committed_delivery_date,&lt;br&gt;customer_notes (messy free text),&lt;br&gt;flags (dog, access, delay...)" style="shape=parallelogram;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;whiteSpace=wrap;perimeter=parallelogramPerimeter;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="250" height="90" as="geometry" />
        </mxCell>

        <!-- Skill A -->
        <mxCell id="df-skill-a" value="&lt;b&gt;Skill A: Extract Constraints&lt;/b&gt;&lt;hr&gt;Input: customer_notes, dates&lt;br&gt;Output: earliest_allowed_date,&lt;br&gt;availability_window, instructions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Skill B -->
        <mxCell id="df-skill-b" value="&lt;b&gt;Skill B: Assess Date Risk&lt;/b&gt;&lt;hr&gt;Input: dates, flags, constraints&lt;br&gt;Output: date_change_recommended,&lt;br&gt;reason_code, revised_date" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="190" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Skill C -->
        <mxCell id="df-skill-c" value="&lt;b&gt;Skill C: Assess Visit Readiness&lt;/b&gt;&lt;hr&gt;Input: job_type, surface, photo, notes&lt;br&gt;Output: tools[], materials[],&lt;br&gt;duration_minutes, confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="300" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Skill D -->
        <mxCell id="df-skill-d" value="&lt;b&gt;Skill D: Assess Safety&lt;/b&gt;&lt;hr&gt;Input: dog_flag, PPE, exchange, notes&lt;br&gt;Output: safety_equipment[],&lt;br&gt;extra_engineer, risks[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="410" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Orchestrator -->
        <mxCell id="df-orch" value="&lt;b&gt;Orchestrator&lt;/b&gt;&lt;br&gt;Composes all four skill&lt;br&gt;outputs into a single&lt;br&gt;SchedulingDecision" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="210" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- Decision Output -->
