        <mxCell id="df-detail" value="&lt;table style=&quot;font-size:11px;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;color:#666;width:110px&quot;&gt;Visit date&lt;/td&gt;&lt;td style=&quot;padding:3px 8px&quot;&gt;&lt;b&gt;2025-11-17&lt;/b&gt; (adjusted for access)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;color:#666&quot;&gt;Tools&lt;/td&gt;&lt;td style=&quot;padding:3px 8px&quot;&gt;fibre splicer, cable rod set, power meter, fibre cleaver&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;color:#666&quot;&gt;Duration&lt;/td&gt;&lt;td style=&quot;padding:3px 8px&quot;&gt;120 minutes&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;color:#666&quot;&gt;Safety&lt;/td&gt;&lt;td style=&quot;padding:3px 8px&quot;&gt;working at height, hard hat required&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;color:#666&quot;&gt;Past delays&lt;/td&gt;&lt;td style=&quot;padding:3px 8px&quot;&gt;20 records (wayleave, CP info, access)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=11;align=left;verticalAlign=top;spacingTop=4;arcSize=8;" vertex="1" parent="1">
